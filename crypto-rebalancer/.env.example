# Binance API credentials.
# For first runs, generate keys on https://testnet.binance.vision and set use_testnet: true in portfolio.yaml.
# When going live, create a mainnet key with SPOT TRADING ONLY, NO WITHDRAWALS, and IP-restrict it.
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
